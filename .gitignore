# Terraform

.terraform/
.terraform.lock.hcl
*.tfstate
*.tfstate.*
*.tfplan
*.tfvars
*.auto.tfvars
*.tfvars.json
crash.log
crash.*.log
override.tf
override.tf.json
*_override.tf
*_override.tf.json

# env/ — real values stay local; only *.example and shared tf files are committed
terraform/env/*
!terraform/env/*.example
!terraform/env/common.variables.tf
!terraform/env/providers.tf

# Keep other example tfvars committable
!terraform.tfvars.example
!*.tfvars.example



# Symlinks (recreated by scripts/link-env.sh)

terraform/infra/*/_remote.base.tf

terraform/infra/*/_remote.network.tf

terraform/infra/*/_remote.*.tf

terraform/infra/*/common.auto.tfvars

terraform/infra/*/common.variables.tf

terraform/infra/*/providers.tf

terraform/infra/dbs/*/_remote.base.tf

terraform/infra/dbs/*/_remote.network.tf

terraform/infra/dbs/*/common.auto.tfvars

terraform/infra/dbs/*/common.variables.tf

terraform/infra/dbs/*/providers.tf

terraform/infra/dbs/*/postgresql.auto.tfvars

terraform/infra/dbs/*/redis.auto.tfvars

terraform/infra/dbs/*/servicebus.auto.tfvars

terraform/infra/security/*/common.auto.tfvars

terraform/infra/security/*/common.variables.tf

terraform/infra/security/*/providers.tf

terraform/infra/security/*/_remote.base.tf

terraform/infra/security/*/_remote.network.tf

terraform/infra/security/*/_remote.identity.tf

terraform/infra/security/*/keyvault.auto.tfvars

terraform/infra/security/*/acr.auto.tfvars

terraform/infra/aks/_remote.network.tf

terraform/infra/aks/_remote.identity.tf

terraform/infra/aks/_remote.acr.tf



# Secrets & credentials

.env
.env.*
!.env.example
secrets/
k8s/secret.yaml

*.pem

credentials.json



# IDE

.vscode/

.idea/

*.swp

*.swo



# OS

.DS_Store

Thumbs.db



# Logs

*.log

logs/



# App source clone (separate repo — clone locally)
repo/

__pycache__/

.venv/

venv/

